rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================================
    // USERS
    // =========================================================================
    match /users/{userId} {
      // Anyone authenticated can read basic profile info
      allow read: if request.auth != null;
      // Users can only write their own document
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId
        // Prevent users from modifying server-managed fields
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['rank', 'totalXP', 'level', 'currentStreak', 'bestStreak']);
    }

    // =========================================================================
    // STEP LOGS
    // =========================================================================
    match /step_logs/{logId} {
      // Users can read/write their own step logs
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create, update: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
    }

    // =========================================================================
    // BATTLES
    // =========================================================================
    match /battles/{battleId} {
      // Participants can read any battle they're in
      allow read: if request.auth != null;
      // Authenticated users can create battles
      allow create: if request.auth != null
        && request.resource.data.createdBy == request.auth.uid;
      // Participants can update (step counts, accept)
      allow update: if request.auth != null;
      // Only creator can delete (cancel pending)
      allow delete: if request.auth != null
        && resource.data.createdBy == request.auth.uid
        && resource.data.status == 'pending';
    }

    // =========================================================================
    // MISSIONS (read-only for clients, admin-written)
    // =========================================================================
    match /missions/{missionId} {
      allow read: if request.auth != null;
      allow write: if false; // Only Cloud Functions / admin
    }

    // =========================================================================
    // USER MISSION PROGRESS
    // =========================================================================
    match /user_mission_progress/{progressId} {
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create, update: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
    }

    // =========================================================================
    // CLANS
    // =========================================================================
    match /clans/{clanId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && request.auth.uid in resource.data.memberIds;
      allow delete: if request.auth != null
        && resource.data.captainId == request.auth.uid;

      // Clan members subcollection
      match /members/{memberId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/clans/$(clanId)).data.memberIds;
      }
    }

    // =========================================================================
    // CLAN BATTLES
    // =========================================================================
    match /clan_battles/{battleId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }

    // =========================================================================
    // FRIEND RELATIONSHIPS
    // =========================================================================
    match /friend_relationships/{relationshipId} {
      allow read: if request.auth != null
        && (resource.data.fromUserId == request.auth.uid
            || resource.data.toUserId == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.fromUserId == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.toUserId == request.auth.uid;
    }

    // =========================================================================
    // NOTIFICATIONS
    // =========================================================================
    match /notifications/{notificationId} {
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if false; // Only Cloud Functions
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid; // Mark as read
    }

    // =========================================================================
    // LEADERBOARD SNAPSHOTS (read-only, written by Cloud Functions)
    // =========================================================================
    match /leaderboard_snapshots/{userId} {
      allow read: if request.auth != null;
      allow write: if false; // Only Cloud Functions
    }

    // =========================================================================
    // SOURCE STEP HOURLY  (per-source step breakdown, hourly buckets)
    // Doc id format: {userId}_{yyyy-MM-dd-HH UTC}
    // Required composite index:
    //   collection: source_step_hourly
    //   fields: userId asc, hourStart desc
    // =========================================================================
    match /source_step_hourly/{logId} {
      // A user can read only their own hourly logs.
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      // A user can create / upsert their own logs.
      allow create, update: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      // No client-side deletion (analytics retention is handled server-side).
      allow delete: if false;
    }
  }
}
